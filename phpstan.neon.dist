includes:
  - vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
  level: 8
  paths:
    - wp-ai-connector.php
    - src
  bootstrapFiles:
    - vendor/szepeviktor/phpstan-wordpress/bootstrap.php
  treatPhpDocTypesAsCertain: false
  reportUnmatchedIgnoredErrors: true
  checkMissingIterableValueType: true
  excludePaths:
    # WooCommerce classes (WC_Order, WC_Product, wc_get_orders, etc.) are only available
    # when WooCommerce is active. PHPStan runs without WC installed.
    - src/Modules/WooCommerce

  ignoreErrors:
    # WP_CLI is loaded conditionally; unavailable to PHPStan analysis.
    - message: '#(unknown class WP_CLI|Call to static method .+ on an unknown class WP_CLI)#'
      paths:
        - src/CLI/KeyCommand.php
        - src/Core/Plugin.php
