{
  "name": "ljutaev/wp-ai-connector",
  "description": "Lightweight REST API & MCP connector for WordPress. Manage your site from Claude, ChatGPT, Cursor, and the terminal.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "keywords": [
    "wordpress",
    "wordpress-plugin",
    "rest-api",
    "mcp",
    "ai",
    "claude",
    "chatgpt",
    "cursor",
    "automation",
    "headless",
    "connector"
  ],
  "homepage": "https://github.com/ljutaev/wp-ai-connector",
  "support": {
    "issues": "https://github.com/ljutaev/wp-ai-connector/issues",
    "source": "https://github.com/ljutaev/wp-ai-connector"
  },
  "authors": [
    {
      "name": "Oleksandr Lukashuk",
      "email": "ljutaev@gmail.com",
      "role": "Author"
    }
  ],
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "phpstan/phpstan": "^1.11",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "wp-coding-standards/wpcs": "^3.1",
    "squizlabs/php_codesniffer": "^3.10",
    "phpcompatibility/php-compatibility": "^9.3",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "yoast/phpunit-polyfills": "^2.0",
    "brain/monkey": "^2.6"
  },
  "autoload": {
    "psr-4": {
      "WPAIConnector\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WPAIConnector\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:unit": "phpunit --testsuite=unit",
    "test:integration": "phpunit --testsuite=integration",
    "lint": "phpcs",
    "lint:fix": "phpcbf",
    "analyse": "phpstan analyse",
    "check": [
      "@lint",
      "@analyse",
      "@test"
    ]
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
